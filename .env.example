# Пароль для входа в панель управления сайтом
# ОБЯЗАТЕЛЬНО смените на свой пароль перед запуском!
ADMIN_PASSWORD=admin123

# Секретный ключ для безопасности сессий
# Сгенерируйте случайную строку длиной 32+ символа
ADMIN_SECRET=замените-это-на-случайную-строку-из-букв-и-цифр

# Режим работы (не меняйте)
# Secure-cookie mode for admin auth: auto, true, or false
# Set false when the admin panel is opened via plain HTTP without HTTPS
ADMIN_COOKIE_SECURE=auto

# Debug logging
DEBUG_MODE=false
LOG_LEVEL=info

# Runtime content storage
# Для Docker/VPS живой контент лучше хранить отдельно от tracked-файлов.
CONTENT_FILE_PATH=/app/runtime-data/content.json
# Папка на хосте для Docker volume. Можно указать абсолютный путь на VPS.
CONTENT_STORAGE_DIR=./runtime-data

NODE_ENV=production
