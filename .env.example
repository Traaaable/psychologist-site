# Пароль для входа в панель управления сайтом
# ОБЯЗАТЕЛЬНО смените на свой пароль перед запуском!
ADMIN_PASSWORD=admin123

# Секретный ключ для безопасности сессий
# Сгенерируйте случайную строку длиной 32+ символа
ADMIN_SECRET=замените-это-на-случайную-строку-из-букв-и-цифр

# Режим работы (не меняйте)
NODE_ENV=production
